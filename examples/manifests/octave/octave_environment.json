{
  "name": "octave_environment",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.octave.environment:OctaveEnvironmentProbeComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "task",
        "type": "OctaveExperimentSpec",
        "required": true,
        "description": "Probe Octave binary, package, and workspace readiness before compilation.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "environment",
        "type": "OctaveEnvironmentReport",
        "mode": "sync",
        "description": "Return octave-cli availability, package facts, and promotion-blocking prerequisites."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "octave.environment.probe",
        "description": "Report Octave runtime readiness for downstream wrapper compilation and execution."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "octave_environment.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "read-only",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "read-only"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "octave.environment.probe"
  ],
  "bins": [
    "octave-cli"
  ]
}
