{
  "name": "moose_input_compiler",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.moose.input_compiler:MooseInputCompilerComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "task",
        "type": "MooseProblemSpec",
        "required": true,
        "description": "Compile a MOOSE problem spec into a run plan."
      },
      {
        "name": "environment",
        "type": "MooseEnvironmentReport",
        "required": false,
        "description": "Optional environment report for prerequisite checks."
      }
    ],
    "outputs": [
      {
        "name": "plan",
        "type": "MooseRunPlan",
        "mode": "sync",
        "description": "Return a compiled MOOSE run plan."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "moose.input.compile",
        "description": "Compile typed MOOSE specifications into executable input plans."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "moose_input_compiler.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "workspace-write",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "workspace-write"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": ["moose.input.compile"]
}
