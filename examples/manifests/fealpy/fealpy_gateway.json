{
  "name": "fealpy_gateway",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.fealpy.gateway:FealpyGatewayComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "task",
        "type": "FealpyProblemSpec",
        "required": false,
        "description": "Accept a fealpy PDE problem specification for issue and dispatch.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "task",
        "type": "FealpyProblemSpec",
        "mode": "sync",
        "description": "Emit the normalized fealpy task specification for downstream probing and compilation."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "fealpy.task.issue",
        "description": "Issue fealpy PDE benchmark tasks."
      }
    ],
    "requires": [
      {
        "name": "fealpy.environment.probe",
        "description": "Require environment readiness before compilation."
      },
      {
        "name": "fealpy.compile",
        "description": "Require script compilation for accepted task specifications."
      }
    ],
    "slots": [
      {
        "slot": "fealpy_gateway.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "workspace-write",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "workspace-write"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "fealpy.task.issue"
  ],
  "requires": [
    "fealpy.environment.probe",
    "fealpy.compile"
  ],
  "deps": {
    "components": [],
    "capabilities": [
      "fealpy.environment.probe",
      "fealpy.compile"
    ]
  },
  "bins": []
}
