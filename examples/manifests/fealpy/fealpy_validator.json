{
  "name": "fealpy_validator",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.fealpy.validator:FealpyValidatorComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "plan",
        "type": "FealpyRunPlan",
        "required": false,
        "description": "Optional plan reference for context."
      },
      {
        "name": "artifact",
        "type": "FealpyRunArtifact",
        "required": true,
        "description": "Accept a run artifact with computed error metrics.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "validation_report",
        "type": "FealpyValidationReport",
        "mode": "sync",
        "description": "Return validation report with L2/H1 tolerance checks and issues."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "fealpy.validate.report",
        "description": "Validate fealpy run artifacts against L2/H1 error tolerances."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "fealpy_validator.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": true,
    "mutability": "mutable",
    "sandbox_profile": "read-only",
    "hot_swap": false
  },
  "policy": {
    "sandbox": {
      "tier": "read-only"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "fealpy.validate.report"
  ],
  "bins": []
}
