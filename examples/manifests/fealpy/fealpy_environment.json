{
  "name": "fealpy_environment",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.fealpy.environment:FealpyEnvironmentProbeComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "task",
        "type": "FealpyProblemSpec",
        "required": true,
        "description": "Probe fealpy installation, backend availability, and PDE model readiness.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "environment",
        "type": "FealpyEnvironmentReport",
        "mode": "sync",
        "description": "Return fealpy version, backend status, and PDE family availability."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "fealpy.environment.probe",
        "description": "Report fealpy runtime readiness for downstream compilation and execution."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "fealpy_environment.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "read-only",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "read-only"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "fealpy.environment.probe"
  ],
  "bins": []
}
