{
  "name": "pycfd_environment",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.pycfd.environment:PyCFDEnvironmentProbeComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "task",
        "type": "PyCFDProblemSpec",
        "required": true,
        "description": "Probe PyCFD source path, numpy availability, Solvers.py importability, and case type readiness.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "environment",
        "type": "PyCFDEnvironmentReport",
        "mode": "sync",
        "description": "Return PyCFD path, Python version, and case type availability."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "pycfd.environment.probe",
        "description": "Report PyCFD runtime readiness for downstream compilation and execution."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "pycfd_environment.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "read-only",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "read-only"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "pycfd.environment.probe"
  ],
  "bins": []
}
