{
  "name": "abacus_executor",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.abacus.executor:AbacusExecutorComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "plan",
        "type": "AbacusRunPlan",
        "required": true,
        "description": ""
      }
    ],
    "outputs": [
      {
        "name": "run",
        "type": "AbacusRunArtifact",
        "mode": "sync",
        "description": ""
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "abacus.scf.run",
        "description": ""
      },
      {
        "name": "abacus.nscf.run",
        "description": ""
      },
      {
        "name": "abacus.relax.run",
        "description": ""
      },
      {
        "name": "abacus.md.run",
        "description": ""
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "abacus_executor.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "workspace-write",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "workspace-write"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": true,
      "required_claims": []
    }
  },
  "state_schema_version": 1
}
