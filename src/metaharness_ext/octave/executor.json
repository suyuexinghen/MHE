{
  "name": "octave_executor",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.octave.executor:OctaveExecutorComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "plan",
        "type": "OctaveRunPlan",
        "required": true,
        "description": "Execute a compiled wrapper-first Octave run plan.",
        "cardinality": "one"
      },
      {
        "name": "environment",
        "type": "OctaveEnvironmentReport",
        "required": false,
        "description": "Optional probe report used to reject unavailable Octave environments before execution.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "run",
        "type": "OctaveRunArtifact",
        "mode": "sync",
        "description": "Return stdout, stderr, declared artifacts, warnings, and execution status."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "octave.execute.run",
        "description": "Execute octave-cli in managed workspaces and collect declared artifacts."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "octave_executor.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "workspace-write",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "workspace-write"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "octave.execute.run"
  ],
  "requires": [
    "octave.script.compile",
    "octave.environment.probe"
  ],
  "deps": {
    "components": [],
    "capabilities": [
      "octave.script.compile",
      "octave.environment.probe"
    ]
  },
  "bins": [
    "octave-cli"
  ]
}
