{
  "name": "octave_study",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.octave.study:OctaveStudyComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "study",
        "type": "OctaveStudySpec",
        "required": true,
        "description": "Run a controlled Octave parameter study over typed task mutations.",
        "cardinality": "one"
      }
    ],
    "outputs": [
      {
        "name": "report",
        "type": "OctaveStudyReport",
        "mode": "sync",
        "description": "Return trial summaries, recommended parameters, and convergence evidence."
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "octave.study.run",
        "description": "Run controlled Octave parameter sweeps from typed study specifications."
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "octave_study.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": "workspace-write",
    "hot_swap": true
  },
  "policy": {
    "sandbox": {
      "tier": "workspace-write"
    },
    "credentials": {
      "requires_subject": false,
      "allow_inline_credentials": false,
      "required_claims": []
    }
  },
  "state_schema_version": 1,
  "provides": [
    "octave.study.run"
  ],
  "requires": [
    "octave.script.compile",
    "octave.execute.run",
    "octave.validate.report"
  ],
  "deps": {
    "components": [],
    "capabilities": [
      "octave.script.compile",
      "octave.execute.run",
      "octave.validate.report"
    ]
  }
}
