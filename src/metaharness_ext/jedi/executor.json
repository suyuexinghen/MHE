{
  "name": "jedi_executor",
  "version": "0.1.0",
  "kind": "core",
  "entry": "metaharness_ext.jedi.executor:JediExecutorComponent",
  "harness_version": ">=0.1.0",
  "contracts": {
    "inputs": [
      {
        "name": "plan",
        "type": "JediRunPlan",
        "required": true,
        "description": ""
      }
    ],
    "outputs": [
      {
        "name": "run",
        "type": "JediRunArtifact",
        "mode": "sync",
        "description": ""
      }
    ],
    "events": [],
    "provides": [
      {
        "name": "jedi.schema.generate",
        "description": ""
      },
      {
        "name": "jedi.validate_only.run",
        "description": ""
      }
    ],
    "requires": [],
    "slots": [
      {
        "slot": "jedi_executor.primary",
        "binding": "primary",
        "required": true
      }
    ]
  },
  "safety": {
    "protected": false,
    "mutability": "mutable",
    "sandbox_profile": null,
    "hot_swap": true
  },
  "state_schema_version": 1,
  "provides": [
    "jedi.schema.generate",
    "jedi.validate_only.run"
  ]
}
