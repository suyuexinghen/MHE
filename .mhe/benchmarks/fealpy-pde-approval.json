{
  "version": 1,
  "benchmark_suite": "fealpy-pde",
  "policy_ref": ".mhe/benchmarks/comparison-approval.json",
  "approval_profile": "fealpy_pde_benchmark_admin_approval",
  "approval_manifest": ".mhe/approvals/fealpy_pde_benchmark_approval.json",
  "approval_required": true,
  "applies_to": {
    "cases": ["*"],
    "lanes": ["extension", "direct", "agent", "comparison"],
    "outputs": [
      "summary.json",
      "attempt_log.json",
      "result_bundle.json",
      "repeat_summary.json",
      "run_manifest.json",
      "manager_facing_report"
    ]
  },
  "lane_specific_gates": {
    "direct": {
      "requires_human_review_of_generated_code": true,
      "reference_ground_truth": "extension_lane_compiler_output",
      "api_surface_key": "installed_fealpy_version_actual_imports"
    },
    "agent": {
      "requires_spec_preflight_pass": true,
      "requires_extension_pipeline_integrity": true
    },
    "extension": {
      "requires_compiler_determinism_review": true,
      "requires_tolerance_table_review": true
    }
  },
  "required_before_claims": [
    "real_tool_execution_claim",
    "direct_vs_agent_lane_superiority_claim",
    "manager_facing_promotion_claim",
    "pde_solver_accuracy_claim"
  ],
  "claim_boundaries": {
    "dry_run_is_not_numerical_evidence": true,
    "admin_approval_is_necessary_not_sufficient": true,
    "real_direct_agent_lanes_required_for_lane_superiority": true,
    "acp_or_claude_review_is_evidence_only": true,
    "direct_lane_generated_code_must_be_reviewed_before_claims": true,
    "compiler_output_is_ground_truth_for_tolerance_reference": true
  }
}
